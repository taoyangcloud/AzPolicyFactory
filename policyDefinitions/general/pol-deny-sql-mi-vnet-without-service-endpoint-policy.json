{
  "name": "pol-deny-sql-mi-vnet-without-service-endpoint-policy",
  "properties": {
    "displayName": "Virtual Network With SQL MI Subnet Must Have Storage Service Endpoint and Endpoint Policy Configured",
    "description": "This policy enforces any subnets with SQL MI Delegation must have Storage Service Endpoint and a Service Endpoint Policy configured.",
    "metadata": {
      "category": "Network Security",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "mode": "All",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/virtualNetworks"
          },
          {
            "count": {
              "field": "Microsoft.Network/virtualNetworks/subnets[*]",
              "where": {
                "allOf": [
                  {
                    "field": "Microsoft.Network/virtualNetworks/subnets[*].delegations[*].serviceName",
                    "equals": "Microsoft.Sql/managedInstances"
                  },
                  {
                    "anyOf": [
                      {
                        "not": {
                          "field": "Microsoft.Network/virtualNetworks/subnets[*].serviceEndpoints[*].service",
                          "in": [
                            "Microsoft.Storage"
                          ]
                        }
                      },
                      {
                        "value": "[length(field('Microsoft.Network/virtualNetworks/subnets[*].serviceEndpointPolicies[*]'))]",
                        "equals": 0
                      }
                    ]
                  }
                ]
              }
            },
            "greater": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
