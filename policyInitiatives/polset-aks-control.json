          "displayName": "AKSC-008 Effect: Audit Defender Profile",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "AKSC-009_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "AKSC-009 Effect: Disable Command Invoke",
          "description": "Enable or disable the execution of the policy.",
          "portalReview": true
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "AKSC-10_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "AKSC-10 Effect: Azure AD Integration",
          "description": "Enable or disable the execution of the policy.",
          "portalReview": true
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
