        "type": "String",
        "metadata": {
          "displayName": "AKSC-12 Effect: Enable CSI",
          "description": "Enable or disable the execution of the policy",
          "portalReview": true
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "AKSC-12_enableDiskCSI": {
        "type": "String",
        "metadata": {
          "displayName": "AKSC-12: Enable CSI Disk Monitoring",
          "description": "Enable monitoring of disk CSI driver. 'false' will skip monitoring",
          "portalReview": true
        },
        "allowedValues": [
          "true",
          "false"
        ],
        "defaultValue": "true"
      },
      "AKSC-12_enableFileCSI": {
        "type": "String",
        "defaultValue": "true",
        "allowedValues": [
          "true",
          "false"
        ],
        "metadata": {
          "displayName": "AKSC-12: Enable CSI File Monitoring",
          "description": "Enable monitoring of file CSI driver. 'false' will skip monitoring",
          "portalReview": true
        }
      },
      "AKSC-12_enableSnapshotCSI": {
        "type": "String",
        "defaultValue": "true",
        "allowedValues": [
          "true",
          "false"
        ],
        "metadata": {
          "displayName": "AKSC-12: Enable CSI Snapshot Monitoring",
          "description": "Enable monitoring of snapshot CSI driver. 'false' will skip monitoring",
          "portalReview": true
        }
      },
      "AKSC-13_Effect": {
        "type": "String",
        "defaultValue": "Deny",
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "metadata": {
          "displayName": "AKSC-13 Effect: Enforce Private Cluster Effect",
          "description": "AKSC-13 Enforce Private Cluster"
        }
      }
    },
