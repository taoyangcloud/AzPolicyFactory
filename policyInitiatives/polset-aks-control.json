{
  "name": "polset-aks-control",
  "properties": {
    "displayName": "Azure Kubernetes Service Control Plane Policy Initiative",
    "description": "This policy initiative defines the CONTOSO security requirements for Azure Kubernetes Services Control Plane",
    "metadata": {
      "category": "Kubernetes",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "AKSC-001_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-001 Effect: Enforce AKS Azure Policy Add-On",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "AKSC-002_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-002 Effect: AKS Should use Azure CNI Overlay",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "AKSC-003_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-003 Effect: Audit AKS Version",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "AKSC-004_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-004 Effect: Image Vulnerability Resolved",
          "description": "'Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "AuditIfNotExists"
      },
      "AKSC-005_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-005 Effect: Enforce AKS Disk Encryption",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "AKSC-006_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-006 Effect: Disable AKS Local Authentication Methods",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "AKSC-007_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "AKSC-007 Effect: Enforce RBAC",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
