{
  "name": "polset-cosmos-db",
  "properties": {
    "displayName": "Azure Cosmos DB Policy Initiative",
    "description": "This policy initiative defines the foundation security requirements for Azure Cosmos DB",
    "metadata": {
      "category": "Cosmos Database",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "COSMOS-001_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "COSMOS-001 Effect: Restrict Cosmos DB Local Authentication",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "COSMOS-002_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "COSMOS-002 Effect: Cosmos DB Firewall Rule",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "COSMOS-003_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "COSMOS-003 Effect: Cosmos DB Restrict Public Network Access",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "COSMOS-004_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "COSMOS-004 Effect: Cosmos DB CMK Encryption",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "audit",
          "Audit",
          "deny",
          "Deny",
          "disabled",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "COSMOS-005_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "COSMOS-005 Effect: Restrict Cosmos DB Key Based Metadata Write Access",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyDefinitionGroups": [
      {
        "name": "ISO27001-2013_A.12.3.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.12.3.1"
