{
  "name": "polset-readonly-tags",
  "properties": {
    "displayName": "Azure Read Only Resource Tags Policy Initiative",
    "description": "This initiative includes policies that implement the read-only tags that cannot be modified",
    "metadata": {
      "category": "Tags",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "ROTAG-001_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect for policy: Subscription Should have Platform Environment tag",
          "description": "Require Platform Environment tag for the subscription."
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      },
      "ROTAG-002_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect for policy: Resource Group inherit Platform Environment tag from Subscription",
          "description": "Inherit Platform Environment tag for the resource group."
        },
        "allowedValues": [
          "Modify",
          "Disabled"
        ],
        "defaultValue": "Modify"
      },
      "platform-environment_TagValue": {
        "type": "string",
        "allowedValues": [
          "Production",
          "Development",
          "Sandbox",
          "Test"
        ],
        "metadata": {
          "displayName": "Tag Value for the Platform Environment tag on subscription",
          "description": "Require Platform Environment tag value for the subscription."
        }
      },
      "platform-environment_TagName": {
        "type": "string",
        "metadata": {
          "displayName": "Tag Name for the Platform Environment tag on subscription",
          "description": "Require Platform Environment tag value for the subscription and resource group."
        }
      }
    },
    "policyDefinitionGroups": [
      {
        "name": "ISO27001-2013_A.8.2.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.8.2.1"
      },
      {
        "name": "ISO27001-2013_A.8.2.2",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.8.2.2"
      },
      {
        "name": "CB-AZ-037"
      }
    ],
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "ROTAG-001",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-sub-set-tag",
        "parameters": {
          "effect": {
            "value": "[parameters('ROTAG-001_Effect')]"
          },
          "tagName": {
            "value": "[parameters('platform-environment_TagName')]"
          },
          "tagValue": {
            "value": "[parameters('platform-environment_TagValue')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.8.2.1",
          "ISO27001-2013_A.8.2.2",
          "CB-AZ-037"
        ]
      },
      {
        "policyDefinitionReferenceId": "ROTAG-002",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-rg-enforce-tag-from-sub",
        "parameters": {
          "effect": {
            "value": "[parameters('ROTAG-002_Effect')]"
          },
          "tagName": {
            "value": "[parameters('platform-environment_TagName')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.8.2.1",
          "ISO27001-2013_A.8.2.2",
          "CB-AZ-037"
        ]
      }
    ]
  }
}
