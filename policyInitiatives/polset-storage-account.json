{
  "name": "polset-storage-account",
  "properties": {
    "displayName": "Azure Storage Accounts Policy Initiative",
    "description": "This policy initiative defines the security requirements for Storage accounts",
    "metadata": {
      "category": "Storage Account",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "STG-001_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "STG-001 Effect: Storage accounts should use customer-managed key for encryption",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "STG-002_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "STG-002 Effect: Storage account encryption scopes should use double encryption for data at rest",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "STG-003_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-003 Effect: Deploy Storage Account Blob Service Soft Delete",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "STG-003_EvaluationDelay": {
        "type": "string",
        "metadata": {
          "displayName": "STG-003: Evaluation Delay",
          "description": "Specifies when the existence of the related resources should be evaluated. The delay is only used for evaluations that are a result of a create or update resource request. Allowed values are AfterProvisioning, AfterProvisioningSuccess, AfterProvisioningFailure, or an ISO 8601 duration between 0 and 360 minutes."
        },
        "defaultValue": "AfterProvisioning"
      },
      "STG-003_MinimumRetentionInDays": {
        "type": "Integer",
        "metadata": {
          "displayName": "STG-003: Minimum Retention in days",
          "description": "The minimum retention in days for the soft deleted blob. Allowed Value: 1-30"
        },
        "defaultValue": 7
      },
      "STG-003_AllowPermanentDelete": {
        "type": "Boolean",
        "metadata": {
          "displayName": "STG-003: Allow Permanent Delete",
          "description": "Allows deletion of the soft deleted blob versions and snapshots"
        },
        "defaultValue": true
      },
      "STG-004_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-004 Effect: Storage accounts should restrict network access",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-005_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "STG-005 Effect: Storage accounts should restrict network access using virtual network rules",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-006_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-006 Effect: Storage accounts should prevent cross tenant object replication",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-007_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-007 Effect: Storage accounts should prevent shared key access",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-008_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-008 Effect: Secure transfer to storage accounts should be enabled",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-009_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-009 Effect: Restrict Storage Account with public network access",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-010_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-010 Effect: Storage accounts should have the specified minimum TLS version",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "STG-010_MinTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "STG-010: Storage Account Minimum TLS Version",
          "description": "Minimum version of TLS required to access data in the storage account"
        },
        "allowedValues": [
          "TLS1_0",
          "TLS1_1",
          "TLS1_2"
        ],
        "defaultValue": "TLS1_2"
      },
      "STG-011_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-011 Effect: Deploy Advanced Threat Protection on storage accounts",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "STG-011_EvaluationDelay": {
        "type": "string",
        "metadata": {
          "displayName": "STG-011: Evaluation Delay",
          "description": "Specifies when the existence of the related resources should be evaluated. The delay is only used for evaluations that are a result of a create or update resource request. Allowed values are AfterProvisioning, AfterProvisioningSuccess, AfterProvisioningFailure, or an ISO 8601 duration between 0 and 360 minutes."
        },
        "defaultValue": "AfterProvisioning"
      },
      "STG-012_Effect": {
        "type": "string",
        "metadata": {
          "displayName": "STG-012 Effect: Storage accounts should prevent permitted copy scopes from any storage accounts",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
