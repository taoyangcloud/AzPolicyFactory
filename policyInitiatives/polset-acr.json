      },
      {
        "name": "AU_ISM_507"
      },
      {
        "name": "CB-AZ-011"
      },
      {
        "name": "AU_ISM_520",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/AU_ISM_520"
      },
      {
        "name": "AU_ISM_1182",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/AU_ISM_1182"
      }
    ],
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "ACR-001",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-acr-encrypt-with-cmk",
