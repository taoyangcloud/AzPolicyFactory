{
  "name": "polset-acr",
  "properties": {
    "displayName": "Azure Container Registry Policy Initiative",
    "description": "This policy initiative defines the foundation security requirements for Azure Container Registries",
    "metadata": {
      "category": "Container Registry",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "ACR-001_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "ACR-001 Effect: Enforce ACR CMK Encryption",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "ACR-002_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "ACR-002 Effect: Enforce ACR Premium SKU",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "ACR-003_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "ACR-003 Effect: Enforce ACR Disable Public Network Access",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyDefinitionGroups": [
      {
        "name": "A.10.1.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.10.1.1"
      },
      {
        "name": "ISO27001-2013_A.13.1.1",
