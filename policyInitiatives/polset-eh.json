{
  "name": "polset-eh",
  "properties": {
    "displayName": "Azure Event Hub Policy Initiative",
    "description": "This policy initiative defines the foundation security requirements for Azure Event Hub",
    "metadata": {
      "category": "Event Hub",
      "version": "1.0.0",
      "preview": false,
      "deprecated": false
    },
    "parameters": {
      "EH-001_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "EH-001 Effect: Restrict Event Hub Local Authentication",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "EH-002_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "EH-002 Effect: Restrict Event Hub Minimum TLS version",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "EH-002_MinimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "EH-002: Event Hub required minimum TLS version",
          "description": "Minimum version of TLS required to access data in the Event Hub Namespace"
        },
        "allowedValues": [
          "1.0",
          "1.1",
          "1.2"
        ],
        "defaultValue": "1.2"
      },
      "EH-003_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "EH-003 Effect: Event Hub Restrict Public Network Access",
          "description": "'Audit' allows a non-compliant resource to be created, but flags it as non-compliant. 'Deny' blocks the resource creation. 'Disable' turns off the policy."
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      },
      "EH-004_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "EH-004 Effect: Event Hub CMK Encryption",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "EH-005_Effect": {
        "type": "String",
        "metadata": {
          "displayName": "EH-005 Effect: Event Hub Private Endpoint",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "AuditIfNotExists",
          "Disabled"
        ],
        "defaultValue": "AuditIfNotExists"
      }
    },
    "policyDefinitionGroups": [
      {
        "name": "ISO27001-2013_A.8.2.3",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.8.2.3"
      },
      {
        "name": "ISO27001-2013_A.10.1.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.10.1.1"
      },
      {
        "name": "ISO27001-2013_A.12.3.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.12.3.1"
      },
      {
        "name": "ISO27001-2013_A.13.1.2",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.13.1.2"
      },
      {
        "name": "ISO27001-2013_A.13.1.3",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.13.1.3"
      },
      {
        "name": "ISO27001-2013_A.14.1.2",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.14.1.2"
      },
      {
        "name": "ISO27001-2013_A.17.1.1",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.17.1.1"
      },
      {
        "name": "ISO27001-2013_A.17.1.2",
        "additionalMetadataId": "/providers/Microsoft.PolicyInsights/policyMetadata/ISO27001-2013_A.17.1.2"
      },
      {
        "name": "CB-AZ-011"
      }
    ],
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "EH-001",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-deny-eh-local-auth",
        "parameters": {
          "effect": {
            "value": "[parameters('EH-001_Effect')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.12.3.1",
          "ISO27001-2013_A.17.1.1",
          "ISO27001-2013_A.17.1.2"
        ]
      },
      {
        "policyDefinitionReferenceId": "EH-002",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-deny-eh-minimum-tls-version",
        "parameters": {
          "effect": {
            "value": "[parameters('EH-002_Effect')]"
          },
          "minimumTlsVersion": {
            "value": "[parameters('EH-002_MinimumTlsVersion')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.14.1.2",
          "ISO27001-2013_A.10.1.1",
          "ISO27001-2013_A.8.2.3"
        ]
      },
      {
        "policyDefinitionReferenceId": "EH-003",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-deny-eh-public-network-access",
        "parameters": {
          "effect": {
            "value": "[parameters('EH-003_Effect')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.13.1.3"
        ]
      },
      {
        "policyDefinitionReferenceId": "EH-004",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-eh-namespaces-use-cmk-encryption",
        "parameters": {
          "effect": {
            "value": "[parameters('EH-004_Effect')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.12.3.1"
        ]
      },
      {
        "policyDefinitionReferenceId": "EH-005",
        "policyDefinitionId": "{policyLocationResourceId}/providers/Microsoft.Authorization/policyDefinitions/pol-audit-eh-namespaces-use-private-link",
        "parameters": {
          "effect": {
            "value": "[parameters('EH-005_Effect')]"
          }
        },
        "groupNames": [
          "ISO27001-2013_A.13.1.2",
          "CB-AZ-011"
        ]
      }
    ]
  }
}
