{
  "rules": {
    "terminology": {
      "skip": [
        "CodeBlock"
      ],
      "exclude": [
        "GitHub",
        "GitHub[ -]?Action",
        "GitHub Action",
        "GitHub[ -]?Actions",
        "GitHub Actions",
        "GitHub[ -]?Copilot",
        "GitHub Copilot",
        "id",
        "Id"
      ]
    }
  }
}
